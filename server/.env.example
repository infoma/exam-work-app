# 服务端口
PORT=3000

# 数据库配置
# 支持 sqlite 和 postgres
DB_TYPE=sqlite

# PostgreSQL 配置（DB_TYPE=postgres 时生效）
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=password
DB_DATABASE=exam_work_app

# SQLite 配置（DB_TYPE=sqlite 时生效）
DB_SQLITE_PATH=./database.sqlite

# JWT 配置
JWT_SECRET=exam-work-app-secret-key-2026
JWT_EXPIRES_IN=7d

# 文件上传配置
FILE_UPLOAD_DIR=./uploads
FILE_MAX_SIZE=10485760

# AI 配置
# provider: mock | openai | qwen | deepseek
AI_PROVIDER=mock
AI_API_KEY=
AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_MODEL=qwen-plus